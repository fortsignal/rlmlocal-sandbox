{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rlmlocal Sandbox",
  "version": "0.1.5",
  "identifier": "com.rlmlocal.sandbox",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RLMlocal Sandbox",
        "width": 560,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/fortsignal/rlmlocal-sandbox/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ3NzU1MDVFOUQwNzYxNjcKUldSbllRZWRYbEIxMThySlZvMkNWTDRGZmx3bkt3NEtibGJwQXRIdVpHdnhZWFZCQ0xFMVVDTVoK"
    }
  }
}